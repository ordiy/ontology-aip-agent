<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/financial-services/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/financial-services/"
    xmlns:aip="http://aip.example.org/rules#">

    <owl:Ontology rdf:about="http://example.org/ontology/financial-services/">
        <rdfs:label>Financial Services</rdfs:label>
    </owl:Ontology>

    <!-- aip: annotation property declarations -->
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#decisionRule"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#operationSteps"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#requiresApproval"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#rollbackable"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#overridable"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#severity"/>

    <owl:Class rdf:about="http://example.org/ontology/financial-services/Customer">
        <rdfs:label>Customer</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/financial-services/Account">
        <rdfs:label>Account</rdfs:label>
        <aip:decisionRule>IF status='active' AND balance &lt; 0 THEN recommend_freeze_account</aip:decisionRule>
        <aip:operationSteps>1:verify_balance,2:notify_customer,3:update_account_status_to_frozen</aip:operationSteps>
        <aip:requiresApproval>user</aip:requiresApproval>
        <aip:severity>high</aip:severity>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/financial-services/Transaction">
        <rdfs:label>Transaction</rdfs:label>
        <aip:decisionRule>IF amount > 10000 AND type='withdrawal' THEN recommend_fraud_investigation</aip:decisionRule>
        <aip:operationSteps>1:flag_transaction,2:hold_funds,3:notify_compliance_officer</aip:operationSteps>
        <aip:requiresApproval>admin</aip:requiresApproval>
        <aip:severity>critical</aip:severity>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/financial-services/Loan">
        <rdfs:label>Loan</rdfs:label>
        <aip:decisionRule>IF status='active' AND creditScore &lt; 500 THEN recommend_default_risk_review</aip:decisionRule>
        <aip:operationSteps>1:assess_collateral,2:initiate_review_workflow</aip:operationSteps>
        <aip:requiresApproval>user</aip:requiresApproval>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/financial-services/Investment">
        <rdfs:label>Investment</rdfs:label>
    </owl:Class>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/customer_customerId">
        <rdfs:label>customerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/customer_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/customer_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/customer_creditScore">
        <rdfs:label>creditScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/customer_annualIncome">
        <rdfs:label>annualIncome</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/account_accountId">
        <rdfs:label>accountId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/account_accountType">
        <rdfs:label>accountType</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/account_balance">
        <rdfs:label>balance</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/account_openedDate">
        <rdfs:label>openedDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/account_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Account"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/transaction_transactionId">
        <rdfs:label>transactionId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/transaction_amount">
        <rdfs:label>amount</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/transaction_transactionDate">
        <rdfs:label>transactionDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/transaction_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/transaction_description">
        <rdfs:label>description</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Transaction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/loan_loanId">
        <rdfs:label>loanId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/loan_principal">
        <rdfs:label>principal</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/loan_interestRate">
        <rdfs:label>interestRate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/loan_startDate">
        <rdfs:label>startDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/loan_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/loan_termMonths">
        <rdfs:label>termMonths</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/investment_investmentId">
        <rdfs:label>investmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/investment_assetType">
        <rdfs:label>assetType</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/investment_amount">
        <rdfs:label>amount</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/investment_purchaseDate">
        <rdfs:label>purchaseDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/financial-services/investment_currentValue">
        <rdfs:label>currentValue</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Investment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/financial-services/customer_owns_account">
        <rdfs:label>customer_owns_account</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/financial-services/Account"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/financial-services/account_has_transaction">
        <rdfs:label>account_has_transaction</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Account"/>
        <rdfs:range rdf:resource="http://example.org/ontology/financial-services/Transaction"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/financial-services/customer_has_loan">
        <rdfs:label>customer_has_loan</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/financial-services/Loan"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/financial-services/customer_has_investment">
        <rdfs:label>customer_has_investment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/financial-services/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/financial-services/Investment"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
</rdf:RDF>
