<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/education-platform/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/education-platform/"
    xmlns:aip="http://aip.example.org/rules#">

    <owl:Ontology rdf:about="http://example.org/ontology/education-platform/">
        <rdfs:label>Education Platform</rdfs:label>
    </owl:Ontology>

    <!-- aip: annotation property declarations -->
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#decisionRule"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#operationSteps"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#requiresApproval"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#rollbackable"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#overridable"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#severity"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#physicalTable"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#queryEngine"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#partitionKeys"/>

    <owl:Class rdf:about="http://example.org/ontology/education-platform/Student">
        <rdfs:label>Student</rdfs:label>
        <aip:decisionRule>IF gpa &lt; 2.0 THEN recommend_academic_probation</aip:decisionRule>
        <aip:operationSteps>1:verify_gpa_history,2:assign_academic_advisor,3:notify_student_status_change</aip:operationSteps>
        <aip:requiresApproval>user</aip:requiresApproval>
        <aip:physicalTable>iceberg_catalog.education.students</aip:physicalTable>
        <aip:queryEngine>starrocks</aip:queryEngine>
        <aip:partitionKeys>enrollmentDate</aip:partitionKeys>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Course">
        <rdfs:label>Course</rdfs:label>
        <aip:physicalTable>iceberg_catalog.education.courses</aip:physicalTable>
        <aip:queryEngine>starrocks</aip:queryEngine>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Instructor">
        <rdfs:label>Instructor</rdfs:label>
        <aip:physicalTable>iceberg_catalog.education.instructors</aip:physicalTable>
        <aip:queryEngine>starrocks</aip:queryEngine>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Enrollment">
        <rdfs:label>Enrollment</rdfs:label>
        <aip:decisionRule>IF status='enrolled' AND enrolledAt &lt; date('now', '-1 semester') AND grade IS NULL THEN recommend_withdrawal_review</aip:decisionRule>
        <aip:operationSteps>1:check_attendance_record,2:contact_student_warning,3:process_administrative_withdrawal</aip:operationSteps>
        <aip:requiresApproval>user</aip:requiresApproval>
        <aip:physicalTable>iceberg_catalog.education.enrollments</aip:physicalTable>
        <aip:queryEngine>starrocks</aip:queryEngine>
        <aip:partitionKeys>enrolledAt</aip:partitionKeys>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Assignment">
        <rdfs:label>Assignment</rdfs:label>
        <aip:decisionRule>IF dueDate &lt; date('now') THEN recommend_grading_reminders_for_instructor</aip:decisionRule>
        <aip:operationSteps>1:count_unsubmitted_assignments,2:send_instructor_notification</aip:operationSteps>
        <aip:requiresApproval>auto</aip:requiresApproval>
        <aip:physicalTable>iceberg_catalog.education.assignments</aip:physicalTable>
        <aip:queryEngine>starrocks</aip:queryEngine>
        <aip:partitionKeys>dueDate</aip:partitionKeys>
    </owl:Class>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_studentId">
        <rdfs:label>studentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_enrollmentDate">
        <rdfs:label>enrollmentDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_gpa">
        <rdfs:label>gpa</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/course_courseId">
        <rdfs:label>courseId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/course_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/course_credits">
        <rdfs:label>credits</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/course_semester">
        <rdfs:label>semester</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/course_description">
        <rdfs:label>description</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/instructor_instructorId">
        <rdfs:label>instructorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Instructor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/instructor_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Instructor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/instructor_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Instructor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/instructor_department">
        <rdfs:label>department</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Instructor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/instructor_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Instructor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/enrollment_enrollmentId">
        <rdfs:label>enrollmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/enrollment_enrolledAt">
        <rdfs:label>enrolledAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/enrollment_grade">
        <rdfs:label>grade</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/enrollment_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Enrollment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/assignment_assignmentId">
        <rdfs:label>assignmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/assignment_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/assignment_dueDate">
        <rdfs:label>dueDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/assignment_maxScore">
        <rdfs:label>maxScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/assignment_description">
        <rdfs:label>description</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/education-platform/student_enrolls_course">
        <rdfs:label>student_enrolls_course</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://example.org/ontology/education-platform/Enrollment"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/education-platform/enrollment_for_course">
        <rdfs:label>enrollment_for_course</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Enrollment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <ont:cardinality>many-to-one</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/education-platform/instructor_teaches_course">
        <rdfs:label>instructor_teaches_course</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Instructor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/education-platform/course_has_assignment">
        <rdfs:label>course_has_assignment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <rdfs:range rdf:resource="http://example.org/ontology/education-platform/Assignment"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
</rdf:RDF>
