<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/education-platform/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/education-platform/">

    <owl:Ontology rdf:about="http://example.org/ontology/education-platform/">
        <rdfs:label>Education Platform</rdfs:label>
    </owl:Ontology>

    <owl:Class rdf:about="http://example.org/ontology/education-platform/Student">
        <rdfs:label>Student</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Course">
        <rdfs:label>Course</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Instructor">
        <rdfs:label>Instructor</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Enrollment">
        <rdfs:label>Enrollment</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/education-platform/Assignment">
        <rdfs:label>Assignment</rdfs:label>
    </owl:Class>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_studentId">
        <rdfs:label>studentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_enrollmentDate">
        <rdfs:label>enrollmentDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/student_gpa">
        <rdfs:label>gpa</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/education-platform/course_courseId">
        <rdfs:label>courseId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/education-platform/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
