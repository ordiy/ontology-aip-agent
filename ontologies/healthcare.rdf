<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/healthcare-system/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/healthcare-system/"
    xmlns:aip="http://aip.example.org/rules#">

    <owl:Ontology rdf:about="http://example.org/ontology/healthcare-system/">
        <rdfs:label>Healthcare System</rdfs:label>
    </owl:Ontology>

    <!-- aip: annotation property declarations -->
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#decisionRule"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#operationSteps"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#requiresApproval"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#rollbackable"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#overridable"/>
    <owl:AnnotationProperty rdf:about="http://aip.example.org/rules#severity"/>

    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Patient">
        <rdfs:label>Patient</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Doctor">
        <rdfs:label>Doctor</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Appointment">
        <rdfs:label>Appointment</rdfs:label>
        <aip:decisionRule>IF status='scheduled' AND appointmentDate &lt; datetime('now') THEN recommend_mark_no_show</aip:decisionRule>
        <aip:operationSteps>1:verify_attendance,2:update_status_to_no_show,3:notify_patient_reschedule</aip:operationSteps>
        <aip:requiresApproval>auto</aip:requiresApproval>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/Prescription">
        <rdfs:label>Prescription</rdfs:label>
        <aip:decisionRule>IF prescribedDate &lt; date('now', '-1 year') THEN recommend_prescription_renewal_review</aip:decisionRule>
        <aip:operationSteps>1:check_recent_vitals,2:schedule_doctor_consultation</aip:operationSteps>
        <aip:requiresApproval>user</aip:requiresApproval>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/healthcare-system/MedicalRecord">
        <rdfs:label>MedicalRecord</rdfs:label>
    </owl:Class>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_patientId">
        <rdfs:label>patientId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_dateOfBirth">
        <rdfs:label>dateOfBirth</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_bloodType">
        <rdfs:label>bloodType</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_phone">
        <rdfs:label>phone</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/patient_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/doctor_doctorId">
        <rdfs:label>doctorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Doctor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/doctor_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Doctor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/doctor_specialty">
        <rdfs:label>specialty</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Doctor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/doctor_licenseNumber">
        <rdfs:label>licenseNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Doctor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/doctor_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Doctor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_appointmentId">
        <rdfs:label>appointmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_appointmentDate">
        <rdfs:label>appointmentDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_notes">
        <rdfs:label>notes</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/appointment_duration">
        <rdfs:label>duration</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_prescriptionId">
        <rdfs:label>prescriptionId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_medicationName">
        <rdfs:label>medicationName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_dosage">
        <rdfs:label>dosage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_prescribedDate">
        <rdfs:label>prescribedDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/prescription_duration">
        <rdfs:label>duration</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/medicalrecord_recordId">
        <rdfs:label>recordId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/MedicalRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/medicalrecord_diagnosis">
        <rdfs:label>diagnosis</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/MedicalRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/medicalrecord_recordDate">
        <rdfs:label>recordDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/MedicalRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/healthcare-system/medicalrecord_notes">
        <rdfs:label>notes</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/MedicalRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/patient_has_appointment">
        <rdfs:label>patient_has_appointment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/doctor_conducts_appointment">
        <rdfs:label>doctor_conducts_appointment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Doctor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Appointment"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/doctor_writes_prescription">
        <rdfs:label>doctor_writes_prescription</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Doctor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/patient_receives_prescription">
        <rdfs:label>patient_receives_prescription</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/Prescription"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/healthcare-system/patient_has_record">
        <rdfs:label>patient_has_record</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/healthcare-system/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/healthcare-system/MedicalRecord"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>
</rdf:RDF>
