# ontology-aip-agent — environment variable reference
#
# Copy this file to .env (or .env.local for local overrides) and fill in your values.
# .env and .env.local are gitignored — never commit real secrets.
#
# Priority (high → low):
#   existing os.environ > .env.local > .env > config.local.yaml > config.yaml

# ─────────────────────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────────────────────

# Active LLM backend: vertex | openai | openrouter | ollama
LLM_PROVIDER=

# Model name (provider-specific, e.g. gemini-2.5-flash, gpt-4o)
LLM_MODEL=

# Google Vertex AI — path to service account JSON key file
# Leave blank to use Application Default Credentials (gcloud auth application-default login)
VERTEX_CREDENTIALS=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter — https://openrouter.ai/keys  (200+ models under one key)
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────────
# Observability (Langfuse)
# ─────────────────────────────────────────────────────────────

# Set to "true" to enable Langfuse tracing
LANGFUSE_ENABLED=

# Langfuse project keys — https://cloud.langfuse.com (or your self-hosted instance)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse host (leave blank for cloud.langfuse.com)
LANGFUSE_HOST=

# ─────────────────────────────────────────────────────────────
# GCP (Google Cloud Platform)
# ─────────────────────────────────────────────────────────────

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
# Path to a service account JSON file (alternative to VERTEX_CREDENTIALS)
GOOGLE_APPLICATION_CREDENTIALS=

# ─────────────────────────────────────────────────────────────
# Future / Tier 1 Commercial Readiness (placeholders)
# ─────────────────────────────────────────────────────────────

# Data connector hosts (StarRocks / CryptoHouse)
# CRYPTOHOUSE_HOST=

# Caching / state store
# REDIS_URL=

# Audit & memory persistence (PostgreSQL DSNs)
# AUDIT_PG_DSN=
# MEMORY_PG_DSN=

# Default tenant for single-tenant deployments
# DEFAULT_TENANT_ID=
